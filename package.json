{
  "name": "hoot-n-nanny",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "budget": "node scripts/check-bundle-budget.mjs",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm run test && npm run budget"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.53.0",
    "prettier": "^3.6.2",
    "typescript": "^5.4.5",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  }
}
