digraph ImplementGameLoop {
    graph [
        goal="Continuously check the backlog, plan sprints from remaining work, implement them, and loop until the game is fully built.",
        label="Implement Game Loop",
        workdir="/Users/caleb.mchenry/code/me/hoot-n-nanny"
    ]

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="All Done"]

    // ── Step 1: Check backlog ────────────────────────────────────────
    check_backlog [
        shape=parallelogram,
        label="Check Backlog",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && test -s docs/BACKLOG.md && echo 'Backlog exists and is non-empty.' || (echo 'EMPTY' && exit 1)"
    ]

    // ── Step 2: Generate backlog from design docs ────────────────────
    generate_backlog [
        shape=parallelogram,
        label="Generate Backlog",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && claude --dangerously-skip-permissions --model claude-opus-4-6 -p 'Read docs/GAME_DESIGN.md and docs/INTENT.md. Also read all source files if any exist (src/, lib/, etc.). Compare what the design docs describe against what is already implemented. Write docs/BACKLOG.md with a prioritized list of features/tasks that still need to be built. Each item should have a short title, description, and priority (high/medium/low). If everything described in the design docs is already implemented, write only the line DONE as the file contents.'"
    ]

    // ── Step 3: Check if anything remains to do ──────────────────────
    backlog_gate [
        shape=parallelogram,
        label="Check If Work Remains",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && grep -q '^DONE$' docs/BACKLOG.md && exit 0 || exit 1"
    ]

    // ── Step 4: Pick sprint items from backlog ───────────────────────
    pick_sprint_items [
        shape=parallelogram,
        label="Pick Sprint Items",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && claude --dangerously-skip-permissions --model claude-opus-4-6 -p 'Read docs/BACKLOG.md, docs/GAME_DESIGN.md, and docs/INTENT.md. Select 1 or more backlog items that make sense to implement together as a single sprint. Consider dependencies and logical grouping. Write your selection and rationale to docs/sprints/drafts/SPRINT-SELECTION.md including which backlog items are included and why they belong together.'"
    ]

    // ── Step 5a: Clean stale drafts ───────────────────────────────────
    clean_drafts [
        shape=parallelogram,
        label="Clean Stale Drafts",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && rm -f docs/sprints/drafts/NEXT-*.md && echo 'Cleaned stale drafts.'"
    ]

    // ── Step 5b: Fan-out drafts — three independent sprint drafts ────
    fan_out_drafts [shape=component, label="Fan Out Drafts", join_policy="wait_all"]
    fan_in_drafts  [shape=tripleoctagon, label="Fan In Drafts"]

    claude_draft [
        shape=parallelogram,
        label="Claude Sprint Draft",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && claude --dangerously-skip-permissions --model claude-opus-4-6 -p 'Read docs/sprints/drafts/SPRINT-SELECTION.md, docs/BACKLOG.md, docs/GAME_DESIGN.md, and docs/INTENT.md. Design a sprint to implement the selected items. Write an independent sprint draft to docs/sprints/drafts/NEXT-CLAUDE-DRAFT.md with: Overview, Architecture, Implementation phases, Files Summary, Definition of Done, Risks, Dependencies. Be specific and opinionated.'"
    ]

    codex_draft [
        shape=parallelogram,
        label="GPT Sprint Draft",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && codex exec --model gpt-5.4 'Read docs/sprints/drafts/SPRINT-SELECTION.md, docs/BACKLOG.md, docs/GAME_DESIGN.md, and docs/INTENT.md. Design a sprint to implement the selected items. Write an independent sprint draft to docs/sprints/drafts/NEXT-CODEX-DRAFT.md with: Overview, Architecture, Implementation phases, Files Summary, Definition of Done, Risks, Dependencies. Be specific and opinionated.'"
    ]

    gemini_draft [
        shape=parallelogram,
        label="Gemini Sprint Draft",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && gemini --yolo --model gemini-3.1-pro-preview-customtools --prompt 'Read docs/sprints/drafts/SPRINT-SELECTION.md, docs/BACKLOG.md, docs/GAME_DESIGN.md, and docs/INTENT.md. Design a sprint to implement the selected items. Write an independent sprint draft to docs/sprints/drafts/NEXT-GEMINI-DRAFT.md with: Overview, Architecture, Implementation phases, Files Summary, Definition of Done, Risks, Dependencies. Be specific and opinionated.'"
    ]

    // ── Step 6: Fan-out critiques — each reviews the other two ───────
    fan_out_critiques [shape=component, label="Fan Out Critiques", join_policy="wait_all"]
    fan_in_critiques  [shape=tripleoctagon, label="Fan In Critiques"]

    gpt_critique [
        shape=parallelogram,
        label="GPT Critique",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && codex exec --model gpt-5.4 'Read docs/sprints/drafts/NEXT-CODEX-DRAFT.md and docs/sprints/drafts/NEXT-GEMINI-DRAFT.md. Write a critique to docs/sprints/drafts/NEXT-GPT-CRITIQUE.md. For each draft identify: strengths, weaknesses, gaps in risk analysis, missing edge cases, Definition of Done completeness. End with recommendations for the final merged sprint.'"
    ]

    claude_critique [
        shape=parallelogram,
        label="Claude Critique",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && claude --dangerously-skip-permissions --model claude-opus-4-6 -p 'Read docs/sprints/drafts/NEXT-CLAUDE-DRAFT.md and docs/sprints/drafts/NEXT-GEMINI-DRAFT.md. Write a critique to docs/sprints/drafts/NEXT-CLAUDE-CRITIQUE.md. For each draft identify: strengths, weaknesses, gaps in risk analysis, missing edge cases, Definition of Done completeness. End with recommendations for the final merged sprint.'"
    ]

    gemini_critique [
        shape=parallelogram,
        label="Gemini Critique",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && gemini --yolo --model gemini-3.1-pro-preview-customtools --prompt 'Read docs/sprints/drafts/NEXT-CLAUDE-DRAFT.md and docs/sprints/drafts/NEXT-CODEX-DRAFT.md. Write a critique to docs/sprints/drafts/NEXT-GEMINI-CRITIQUE.md. For each draft identify: strengths, weaknesses, gaps in risk analysis, missing edge cases, Definition of Done completeness. End with recommendations for the final merged sprint.'"
    ]

    // ── Step 7: Merge all drafts + critiques into final sprint ───────
    merge_sprint [
        shape=parallelogram,
        label="Merge Sprint",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && claude --dangerously-skip-permissions --model claude-opus-4-6 -p 'Read the draft and critique files in docs/sprints/drafts/NEXT-*.md. Synthesize the best ideas into a final sprint document. Determine the next sprint number by looking at existing SPRINT-*.md files in docs/sprints/ (if none exist, use 001). Write the merged sprint to docs/sprints/SPRINT-NNN.md (replace NNN with the correct zero-padded number). Keep the document focused and concise — prioritize actionable implementation details over lengthy analysis.'"
    ]

    // ── Step 8: Implement the sprint ─────────────────────────────────
    implement [
        shape=parallelogram,
        label="Implement Sprint",
        timeout="1800s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && codex exec --model gpt-5.3-codex 'Read the latest SPRINT-*.md file in docs/sprints/ (the highest numbered one). This is the sprint you need to implement. Read all project files and existing code. Also check if docs/sprints/validation-look-and-feel.md or docs/sprints/validation-bot-wins.md exist — if they do, read them for feedback from a previous validation pass and address any issues noted there. Work through ALL items in the Definition of Done. Implement all required functionality. Run any build/test commands if a build system is configured. Fix any failures. Remove completed items from docs/BACKLOG.md. If no items remain, replace the file contents with the single line DONE. Do NOT commit — just implement and verify.'",
        max_retries=5
    ]

    // ── Step 9: Validation fan-out ─────────────────────────────────
    fan_out_validation [shape=component, label="Fan Out Validation", join_policy="wait_all"]
    fan_in_validation  [shape=tripleoctagon, label="Fan In Validation"]

    validate_look_and_feel [
        shape=parallelogram,
        label="Look & Feel Validation",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && claude --dangerously-skip-permissions --model claude-opus-4-6 -p 'You are validating the visual look and feel of the game. First check if there is a servable UI — look for an index.html, a dev server script in package.json, or similar. If there is no UI to serve yet, write docs/sprints/validation-look-and-feel.md with PASS as the first line and a note that no UI exists yet so this check is not applicable. If a UI does exist, read docs/GAME_DESIGN.md and docs/INTENT.md to understand the visual goals. Use npx @anthropic-ai/agent-browser@latest to launch the game in a browser, navigate through the key screens, and take screenshots. Compare each screenshot against the visual goals described in the design docs. Write a validation report to docs/sprints/validation-look-and-feel.md. For each screen: describe what you see, whether it matches the design goals, and any issues. If all screens honor the visual goals, write PASS as the first line. If there are issues, write FAIL as the first line followed by specific feedback on what needs to change.'"
    ]

    validate_bot_wins [
        shape=parallelogram,
        label="Bot Win Validation",
        timeout="900s",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && claude --dangerously-skip-permissions --model claude-opus-4-6 -p 'You are validating that the bot/AI player can still win the game. First check if a bot or AI player exists in the codebase by searching for bot, ai, or computer player logic. If no bot exists yet, write docs/sprints/validation-bot-wins.md with PASS as the first line and a note that no bot exists yet so this check is not applicable. If a bot does exist, run the game with the bot playing and verify it can win. Write docs/sprints/validation-bot-wins.md — PASS as the first line if the bot wins, FAIL as the first line with details if it cannot.'"
    ]

    // ── Step 10: Validation gate ─────────────────────────────────────
    validation_gate [
        shape=parallelogram,
        label="Check Validation Results",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && grep -q '^PASS' docs/sprints/validation-look-and-feel.md && grep -q '^PASS' docs/sprints/validation-bot-wins.md && echo 'All validations passed' || (echo 'Validation failed' && exit 1)"
    ]

    // ── Step 11: Commit and loop ─────────────────────────────────────
    commit [
        shape=parallelogram,
        label="Commit Sprint",
        tool_command="cd /Users/caleb.mchenry/code/me/hoot-n-nanny && SPRINT=$(ls docs/sprints/SPRINT-*.md | sort -V | tail -1 | sed 's/.*SPRINT-//;s/.md//') && git add -A && git commit -m \"feat: implement Sprint ${SPRINT}\""
    ]

    // ── Edges ────────────────────────────────────────────────────────
    start -> check_backlog

    check_backlog -> backlog_gate        [label="Backlog Exists", condition="outcome=success"]
    check_backlog -> generate_backlog    [label="No Backlog", condition="outcome=fail"]
    check_backlog -> generate_backlog    [label="Fallback"]

    generate_backlog -> backlog_gate

    backlog_gate -> exit                 [label="All Done", condition="outcome=success"]
    backlog_gate -> pick_sprint_items    [label="Work Remains", condition="outcome=fail"]
    backlog_gate -> pick_sprint_items    [label="Fallback"]

    pick_sprint_items -> clean_drafts
    clean_drafts      -> fan_out_drafts

    fan_out_drafts  -> claude_draft
    fan_out_drafts  -> codex_draft
    fan_out_drafts  -> gemini_draft
    claude_draft    -> fan_in_drafts
    codex_draft     -> fan_in_drafts
    gemini_draft    -> fan_in_drafts
    fan_in_drafts   -> fan_out_critiques

    fan_out_critiques  -> gpt_critique
    fan_out_critiques  -> claude_critique
    fan_out_critiques  -> gemini_critique
    gpt_critique       -> fan_in_critiques
    claude_critique    -> fan_in_critiques
    gemini_critique    -> fan_in_critiques
    fan_in_critiques   -> merge_sprint

    merge_sprint -> implement
    implement    -> fan_out_validation

    fan_out_validation  -> validate_look_and_feel
    fan_out_validation  -> validate_bot_wins
    validate_look_and_feel -> fan_in_validation
    validate_bot_wins      -> fan_in_validation
    fan_in_validation      -> validation_gate

    validation_gate -> commit      [label="Pass", condition="outcome=success"]
    validation_gate -> implement   [label="Fix Issues", condition="outcome=fail"]
    validation_gate -> implement   [label="Fallback"]

    commit -> check_backlog
}
